[Unit]
Description=CMS Dashboard Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory={{INSTALL_DIR}}
Environment="PATH={{INSTALL_DIR}}/venv/bin"
ExecStart={{INSTALL_DIR}}/venv/bin/python {{INSTALL_DIR}}/main.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
